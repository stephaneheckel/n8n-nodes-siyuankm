{
  "name": "n8n-nodes-siyuan",
  "version": "2.1.5",
  "description": "n8n community nodes for SiYuan \u2014 manage notebooks, documents, blocks, tags, assets, and search. Includes AI Tool nodes for use with n8n AI agents and a Trigger node for real-time events.",
  "keywords": [
    "n8n-community-node-package",
    "siyuan",
    "note-taking",
    "knowledge-base",
    "ai-agent",
    "ai-tool"
  ],
  "license": "MIT",
  "homepage": "https://github.com/PsycoStea/SiYuan-n8n-nodes#readme",
  "author": {
    "name": "Michael",
    "email": "mbates1401@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PsycoStea/SiYuan-n8n-nodes"
  },
  "bugs": {
    "url": "https://github.com/PsycoStea/SiYuan-n8n-nodes/issues"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsc && gulp build:icons && node -e \"var p=require('./dist/package.json');p.n8n.nodes=p.n8n.nodes.map(function(n){return n.replace('dist/','')});p.n8n.credentials=p.n8n.credentials.map(function(c){return c.replace('dist/','')});require('fs').writeFileSync('./dist/package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "dev": "tsc && cross-env N8N_CUSTOM_EXTENSIONS=dist n8n start",
    "dev:watch": "tsc --watch",
    "format": "prettier nodes credentials lib --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "pnpm build && pnpm lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SiYuanApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SiYuan/SiYuan.node.js",
      "dist/nodes/SiYuanDocumentTool/SiYuanDocumentTool.node.js",
      "dist/nodes/SiYuanSearchTool/SiYuanSearchTool.node.js",
      "dist/nodes/SiYuanTrigger/SiYuanTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.4",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "gulp": "^4.0.2",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.8.2",
    "tsx": "^4.22.1",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.15.0"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": ">=7.0.5",
      "axios": ">=1.8.4",
      "decode-uri-component": ">=0.2.1",
      "braces": ">=3.0.3",
      "micromatch": ">=4.0.8",
      "es5-ext": ">=0.10.63",
      "semver": ">=5.7.2"
    }
  }
}
